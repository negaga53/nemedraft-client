# Default: treat unrecognized files as text and normalize to LF in the repo.
# On checkout (any OS), text files are written with LF.
* text=auto eol=lf

# Explicit text formats — defensive (prevents misclassification by `text=auto`)
*.py             text eol=lf
*.toml           text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf
*.json           text eol=lf
*.md             text eol=lf
*.txt            text eol=lf
*.cfg            text eol=lf
*.ini            text eol=lf
*.sh             text eol=lf
*.spec           text eol=lf
*.html           text eol=lf
*.css            text eol=lf
*.js             text eol=lf
*.svg            text eol=lf
*.sql            text eol=lf
Dockerfile       text eol=lf
Makefile         text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf
.env*            text eol=lf

# Binary formats — never normalize
*.png            binary
*.jpg            binary
*.jpeg           binary
*.gif            binary
*.ico            binary
*.icns           binary
*.pdf            binary
*.zip            binary
*.gz             binary
*.tar            binary
*.bz2            binary
*.7z             binary
*.npz            binary
*.npy            binary
*.pt             binary
*.pth            binary
*.bin            binary
*.parquet        binary
*.arrow          binary
*.so             binary
*.dll            binary
*.dylib          binary
*.exe            binary
*.woff           binary
*.woff2          binary
*.ttf            binary
*.otf            binary

# Windows shell scripts must keep CRLF (cmd.exe requirement)
*.bat            text eol=crlf
*.cmd            text eol=crlf
